#!/usr/bin/env bash
# Cross-compile DArc86 (Win32 variant) via Wine + GHC 8.6.5 Windows i386 bindist.
# DArc86 is a SEPARATE build target for legacy Win7/8/10 32-bit users. It uses
# GHC 8.6.5 (the last Windows i386 bindist) in isolation — the mainline DArc
# Linux x64 and Win64 builds (GHC 9.4.8 / MHS) are untouched.
#
# Archive wire-format is 100% compatible between DArc and DArc86.
#
# Requirements:
#   - wine
#   - GHC 8.6.5 Windows i386 installed at ~/.wine/drive_c/ghc865-i386/
#   - i686-w64-mingw32-g++-posix on host
#   - Lua 5.1 static lib built for i686 at /tmp/out/FreeArc-win86-ghc/liblua5.1.a
# Output: Tests/arc86.exe (PE32 Windows i386 binary)
set -e

exe=Tests/arc86.exe
opt="-O2"
for option; do
  case $option in
    -O*) opt="$option" ;;
  esac
done

GHC_WIN_ROOT="${GHC_WIN_ROOT:-$HOME/.wine/drive_c/ghc865-i386}"
if [[ ! -x "$GHC_WIN_ROOT/bin/ghc.exe" ]]; then
  echo "error: GHC 8.6.5 Windows i386 not found at $GHC_WIN_ROOT/bin/ghc.exe" >&2
  echo "Install: download https://downloads.haskell.org/~ghc/8.6.5/ghc-8.6.5-i386-unknown-mingw32.tar.xz" >&2
  echo "and extract to $GHC_WIN_ROOT (strip-components=1)" >&2
  exit 1
fi

# 1) Build C/C++ objects for Win32
WINOUT="/tmp/out/FreeArc-win86-ghc"
export WINOUT
./compile-win86-c

# 1b) Build Win32Files.c via GHC's bundled gcc (msvcrt) under Wine.
# Host mingw (Ubuntu) targets UCRT; mixing is incompatible with GHC 8.6.
winpath_local() { echo "Z:$(echo "$1" | sed 's|/|\\|g')"; }
HSBASE_INC_WIN="$(winpath_local "$GHC_WIN_ROOT/lib/base-4.12.0.0/include")"
RTS_INC_WIN="$(winpath_local "$GHC_WIN_ROOT/lib/include")"
BIGNUM_INC_WIN="$(winpath_local "$GHC_WIN_ROOT/lib/integer-gmp-1.0.2.0/include")"
WIN32FILES_SRC_WIN="$(winpath_local "$(readlink -f Win32Files.c)")"
WIN32FILES_OUT_WIN="$(winpath_local "$WINOUT/Win32Files.o")"
export WINEDEBUG="${WINEDEBUG:-fixme-all}"
export WINEPATH="C:\\ghc865-i386\\mingw\\bin"
wine "$GHC_WIN_ROOT/mingw/bin/gcc.exe" -c "$WIN32FILES_SRC_WIN" \
  "-I$HSBASE_INC_WIN" "-I$RTS_INC_WIN" "-I$BIGNUM_INC_WIN" -O2 \
  -o "$WIN32FILES_OUT_WIN" 2>&1 | grep -vE "^[0-9a-f]+:fixme:" || true

# 1c) Build ntrljmp.c (Lua longjmp trampoline) via the same Wine-hosted gcc
NTRL_SRC_WIN="$(winpath_local "$(readlink -f HsLua/src/ntrljmp.c)")"
NTRL_OUT_WIN="$(winpath_local "$WINOUT/ntrljmp.o")"
HSLUA_INC_WIN="$(winpath_local "$(readlink -f HsLua/src)")"
LUA_INC_WIN="$(winpath_local "$(readlink -f /tmp/out/FreeArc-win86-ghc-inc/lua5.1 2>/dev/null || echo $HOME/wine-ghc/lua-5.1.5/src)")"
wine "$GHC_WIN_ROOT/mingw/bin/gcc.exe" -c "$NTRL_SRC_WIN" \
  "-I$HSLUA_INC_WIN" "-I$LUA_INC_WIN" -O2 \
  -o "$NTRL_OUT_WIN" 2>&1 | grep -vE "^[0-9a-f]+:fixme:" || true

# 2) Verify Lua i686 lib exists
if [[ ! -f "$WINOUT/liblua5.1.a" ]]; then
  echo "error: $WINOUT/liblua5.1.a missing. Build it with:" >&2
  echo "  cd ~/wine-ghc/lua-5.1.5/src && for s in *.c; do" >&2
  echo "    [[ \"\$s\" =~ ^(lua|luac|print)\\.c\$ ]] && continue" >&2
  echo "    wine $GHC_WIN_ROOT/mingw/bin/gcc.exe -c -O2 \"\$s\" -o \"\${s%.c}.o\"" >&2
  echo "  done && wine $GHC_WIN_ROOT/mingw/bin/ar.exe rcs liblua5.1.a *.o" >&2
  echo "  && cp liblua5.1.a $WINOUT/" >&2
  exit 1
fi

# 3) Run GHC Windows via Wine
htempdir="/tmp/out/FreeArc-win86-ghc-hs"
mkdir -p "$htempdir"

winpath() {
  local p="$1"
  echo "Z:$(echo "$p" | sed 's|/|\\|g')"
}

c_objs=(
  "$WINOUT/Environment.o" "$WINOUT/URL.o" "$WINOUT/Common.o"
  "$WINOUT/CompressionLibrary.o"
  "$WINOUT/C_PPMD.o" "$WINOUT/C_LZP.o" "$WINOUT/C_LZMA.o"
  "$WINOUT/C_GRZip.o" "$WINOUT/C_Dict.o" "$WINOUT/C_REP.o"
  "$WINOUT/C_MM.o" "$WINOUT/C_TTA.o" "$WINOUT/C_Tornado.o"
  "$WINOUT/C_4x4.o" "$WINOUT/C_Delta.o" "$WINOUT/C_External.o"
  "$WINOUT/C_Encryption.o"
  "$WINOUT/Win32Files.o"
  "$WINOUT/ntrljmp.o"
  "$WINOUT/LzmaEnc.o" "$WINOUT/LzmaDec.o" "$WINOUT/Lzma2Enc.o" "$WINOUT/Lzma2Dec.o"
  "$WINOUT/LzFind.o" "$WINOUT/LzFindMt.o" "$WINOUT/LzFindOpt.o"
  "$WINOUT/CpuArch.o" "$WINOUT/Alloc.o" "$WINOUT/Threads.o"
  "$WINOUT/MtCoder.o" "$WINOUT/MtDec.o" "$WINOUT/7zStream.o"
  "$WINOUT/C_7z.o"
  "$WINOUT/sdk_7zArcIn.o" "$WINOUT/sdk_7zBuf.o" "$WINOUT/sdk_7zCrc.o"
  "$WINOUT/sdk_7zCrcOpt.o" "$WINOUT/sdk_7zDec.o" "$WINOUT/sdk_7zFile.o"
  "$WINOUT/sdk_7zStream.o" "$WINOUT/sdk_7zAlloc.o"
  "$WINOUT/sdk_Bcj2.o" "$WINOUT/sdk_Bra.o" "$WINOUT/sdk_Bra86.o" "$WINOUT/sdk_BraIA64.o"
  "$WINOUT/sdk_Delta.o" "$WINOUT/sdk_LzmaDec.o" "$WINOUT/sdk_Lzma2Dec.o"
  "$WINOUT/sdk_Ppmd7.o" "$WINOUT/sdk_Ppmd7Dec.o"
  "$WINOUT/sdk_CpuArch.o" "$WINOUT/sdk_Alloc.o"
)
[[ -f "$WINOUT/C_BCJ.o" ]] && c_objs+=("$WINOUT/C_BCJ.o")

# Windows system libs
win_libs=(-Wl,--allow-multiple-definition -Wl,--whole-archive "$(winpath "$WINOUT/liblua5.1.a")" -Wl,--no-whole-archive -lstdc++ -lpthread -lwinmm -lws2_32 -ladvapi32 -lshell32 -luser32 -lkernel32 -lwininet)

# Haskell CPP defines: no FREEARC_64BIT for Win32
hs_defines=(-DFREEARC_WIN -DFREEARC_INTEL_BYTE_ORDER)

# GHC 8.6 is more permissive re: extensions; keep the same set as GHC 9.4 build
ghc_ext_flags=(
  -XNoMonomorphismRestriction -XFlexibleContexts -XScopedTypeVariables
  -XTypeSynonymInstances -XFlexibleInstances -XMultiParamTypeClasses -XCPP
  -XNondecreasingIndentation -XUndecidableInstances -XOverlappingInstances
  -XLambdaCase -XBangPatterns -XRecursiveDo -XTupleSections
)

# GHC 8.6 on Windows i386 MERGES -optl C objects into per-module Haskell .o via
# incremental `ld -r`. Passing them again to -optl for the final link causes
# duplicate-symbol errors. Pass them only via -pgmlo/-optl-r once so GHC's link
# sees them exactly once. NOTE: this pollutes the final PE import table with a
# 13th bogus ADVAPI32 descriptor containing KERNEL32/WININET/USER32 thunks —
# `fix-arc86-imports.py` runs post-link to split that descriptor properly.
optl_args=()
for o in "${c_objs[@]}"; do
  optl_args+=(-optl "$(winpath "$(readlink -f "$o")")")
done
for l in "${win_libs[@]}"; do optl_args+=(-optl "$l"); done

optc_args=(-optc -I. -optc -ICompression -optc -IHsLua/src -optc -I/tmp/out/FreeArc-win86-ghc-inc/lua5.1 -optc -I/tmp/out/FreeArc-win86-ghc-inc)
for d in "${hs_defines[@]}"; do optc_args+=(-optc "$d"); done

rm -f "$exe"

DARC_DIR="$(pwd)"
HTEMP_WIN="$(winpath "$htempdir")"

export WINEDEBUG="${WINEDEBUG:-fixme-all}"
export WINEPATH="C:\\ghc865-i386\\mingw\\bin"

cd "$DARC_DIR"

# Stage 1: --make + compile only (-c). This produces all .o files in $htempdir but
# does NOT link. Then we strip .idata sections from the polluted .o files (the ones
# where GHC's per-module `ld -r` bundled C objects with their import descriptors
# inside). Stripping forces the final link to resolve _imp_* refs from libkernel32.a
# etc., yielding a clean PE import table without the bogus ADVAPI32 descriptor that
# trips the Win7 loader (STATUS_ENTRYPOINT_NOT_FOUND).
wine "$GHC_WIN_ROOT/bin/ghc.exe" \
  -i. -iCompression -iHsLua/src -icompat-win \
  -odir "$HTEMP_WIN" -hidir "$HTEMP_WIN" \
  $opt -threaded \
  "${hs_defines[@]}" \
  "${optc_args[@]}" \
  "${ghc_ext_flags[@]}" \
  -fno-warn-deprecated-flags -w \
  "${optl_args[@]}" \
  --make Arc.hs \
  -main-is Arc \
  -c -no-link 2>/tmp/ghc86.err | tr -d '\000'
cat /tmp/ghc86.err | tr -d '\000' | grep -vE "^[0-9a-f]+:fixme:|^[0-9a-f]+:stub|server_get_file_info|NtQuerySystemInformation" || true

# Strip .idata$* sections from any Haskell .o that absorbed them via ld -r.
for o in $(find "$htempdir" -name "*.o"); do
  if i686-w64-mingw32-objdump -h "$o" 2>/dev/null | grep -q '\.idata'; then
    i686-w64-mingw32-objcopy \
      --remove-section='.idata$2' --remove-section='.idata$4' \
      --remove-section='.idata$5' --remove-section='.idata$6' \
      --remove-section='.idata$7' "$o"
  fi
done

# Stage 2: link. Re-invoke GHC --make; with all .o present and source unchanged,
# it skips compile and proceeds straight to link, picking up the stripped .o files.
wine "$GHC_WIN_ROOT/bin/ghc.exe" \
  -i. -iCompression -iHsLua/src -icompat-win \
  -odir "$HTEMP_WIN" -hidir "$HTEMP_WIN" \
  $opt -threaded \
  "${hs_defines[@]}" \
  "${optc_args[@]}" \
  "${ghc_ext_flags[@]}" \
  -fno-warn-deprecated-flags -w \
  "${optl_args[@]}" \
  --make Arc.hs \
  -main-is Arc \
  -o "$(winpath "$(readlink -f "$exe" 2>/dev/null || echo "$DARC_DIR/$exe")")" 2>/tmp/ghc86.err | tr -d '\000'
cat /tmp/ghc86.err | tr -d '\000' | grep -vE "^[0-9a-f]+:fixme:|^[0-9a-f]+:stub|server_get_file_info|NtQuerySystemInformation" || true

if [[ -f "$exe" ]]; then
  echo ""
  echo "Built: $exe"
  file "$exe"
else
  echo "error: build did not produce $exe" >&2
  exit 1
fi
